{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "roomctl hook prompt",
            "timeout": 50,
            "statusMessage": "Checking Room guardrails"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "roomctl hook pre-tool",
            "timeout": 50,
            "statusMessage": "Checking Room guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "roomctl hook post-tool",
            "timeout": 50,
            "statusMessage": "Checking Room diff guardrails"
          }
        ]
      }
    ]
  }
}
